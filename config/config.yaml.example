# ──────────────────────────────────────────────────────────────
#  books-of-time  —  应用配置示例
#  复制为 config.yaml 并填入实际值
# ──────────────────────────────────────────────────────────────

database:
  # PostgreSQL 异步连接 URL（asyncpg driver）
  # 格式: postgresql+asyncpg://user:password@host:port/dbname
  url: "postgresql+asyncpg://postgres:password@localhost:5432/books_of_time"

  # 连接池设置
  pool_size: 5
  max_overflow: 10
  pool_pre_ping: true
  echo: false  # SQL 日志（调试时设为 true）

storage:
  # 仅控制 raw payload；media 始终保存到本地 media_dir。
  backend: filesystem
  raw_dir: ./data/raw
  media_dir: ./data/media
  minio:
    endpoint: ""
    access_key: ""
    secret_key: ""
    bucket: books-of-time-raw
    prefix: raw
    secure: true
    create_bucket: false

accounts:
  enabled: true
  active_account_id: default
  credentials_path: ./data/accounts/credentials.enc
  key_path: ./data/accounts/master.key
  history_limit: 5
  auto_refresh: true
  refresh_check_seconds: 21600

http:
  timeout_seconds: 10
  user_agent: "BooksOfTime/0.1 research collector"

rate_limit:
  global:
    rps: 1.0
    burst: 3
  host:bilibili:
    rps: 0.8
    burst: 2
  bilibili:video_stats:
    rps: 0.5
    burst: 2
  bilibili:user_video_list:
    rps: 0.2
    burst: 1
  bilibili:comment_hot:
    rps: 0.2
    burst: 1
  bilibili:comment_latest:
    rps: 0.2
    burst: 1
  bilibili:comment_reply:
    rps: 0.1
    burst: 1
  bilibili:media_image:
    rps: 0.2
    burst: 1

scheduler:
  lease_seconds: 120
  default_retry_delay_seconds: 300
  max_retries: 3
  discovery_scan_seconds: 60
  discovery_start_hour: 10
  discovery_stop_hour: 22
  discovery_timezone: Asia/Shanghai
  discovery_focus_times: ["11:00", "12:00", "13:00", "18:00", "19:00", "19:30", "20:00"]

service:
  roles: [worker, scheduler]
  worker_idle_sleep_seconds: 5
  scheduler_idle_sleep_seconds: 1
  scheduler_lease_seconds: 60
  heartbeat_seconds: 10
  heartbeat_timeout_seconds: 30
  request_failure_window_seconds: 3600
  shutdown_grace_seconds: 60

operations:
  alerts:
    enabled: true
    evaluation_seconds: 60
    worker_heartbeat_timeout_seconds: 90
    pending_task_threshold: 1000
    oldest_pending_seconds: 900
    request_failure_window_seconds: 3600
    request_failure_min_pages: 20
    request_failure_rate: 0.25
    scheduled_job_failure_threshold: 3
    repeat_notification_seconds: 3600

latest_comments:
  max_scan_seconds: 55
  page_retry_attempts: 3
  page_retry_backoff_seconds: [1, 3, 5]

request_budget:
  s:
    per_round: 200
    hot_pages: 20
    latest_pages: 30
    reply_roots: 30
  a:
    per_round: 80
    hot_pages: 10
    latest_pages: 10
    reply_roots: 10
  b:
    per_round: 20
    hot_pages: 3
    latest_pages: 3
    reply_roots: 2
  c:
    per_round: 3
    hot_pages: 1
    latest_pages: 0
    reply_roots: 0

snapshot_cohorts:
  # C3 may be enabled only in shadow mode; live ownership moves in C7.
  enabled: false
  policy_version: cohort-default-v1
  rollout_mode: shadow
  planning_seconds: 30
  timezone: Asia/Shanghai
  checkpoint_hours: [6, 12, 18, 24]
  checkpoint_max_lateness_minutes: 60
  downgrade_confirmations: 2
  tier_policy:
    official_s_age_hours: 6
    reassess_after_24h_minutes: 60
    hot_turnover_confirmations: 2
    s:
      view_growth_per_hour: 6000
      comment_growth_per_hour: 60
      hot_top20_turnover_ratio: 0.35
    a:
      view_growth_per_hour: 1200
      comment_growth_per_hour: 20
      hot_top20_turnover_ratio: 0.20
    b:
      view_growth_per_hour: 300
      comment_growth_per_hour: 5
  lifecycle:
    dormant_after_days: 7
    archive_after_days: 30
    dormant_interval_minutes: 1440
    archived_metric_probe_minutes: 10080
  activity_windows:
    defaults:
      - {name: lunch, start: "11:30", end: "13:30"}
      - {name: dinner, start: "17:30", end: "20:30"}
      - {name: night, start: "21:30", end: "00:30"}
  tier_intervals_minutes:
    s: {active: 2, normal: 10}
    a: {active: 10, normal: 30}
    b: {active: 30, normal: 60}
    c: {active: 60, normal: 120}

watchlist:
  hot_max_position: 3
  reply_growth_min: 5
  like_growth_min: 20
  recent_first_seen_bonus: 2
  # Configure project-specific terms explicitly; no subjective defaults are set.
  controversy_keywords: []

analysis:
  # Version this value whenever terms or category meanings change.
  # Matches are evidence counts, not exclusive labels for comments or users.
  stance_lexicon:
    version: "2026-07-v1"
    support: ["赞同", "说得对", "支持这个观点"]
    criticism: ["质疑", "反对", "不认同"]
    neutral: ["求证", "观望", "等待回应"]

discovery:
  matrix_uids: []
  game_uid_pools:
    genshin_impact:
      game_id: genshin_impact
      official: true
      monitored: true
      uids: [401742377]  # 原神
    wuthering_waves:
      game_id: wuthering_waves
      official: true
      monitored: true
      uids: [1955897084]  # 鸣潮
    honkai_star_rail:
      game_id: honkai_star_rail
      official: true
      monitored: true
      uids: [1340190821]  # 崩坏：星穹铁道
    zenless_zone_zero:
      game_id: zenless_zone_zero
      official: true
      monitored: true
      uids: [1636034895]  # 绝区零
    honkai_impact_3rd:
      game_id: honkai_impact_3rd
      official: true
      monitored: true
      uids: [27534330]  # 崩坏3第一偶像爱酱
    arknights_endfield:
      game_id: arknights_endfield
      official: true
      monitored: true
      uids: [1265652806]  # 明日方舟：终末地
    arknights:
      game_id: arknights
      official: true
      monitored: true
      uids: [161775300]  # 明日方舟
  event_uid_pools: {}
