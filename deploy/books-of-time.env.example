BOT_CONFIG=/opt/books-of-time/config/config.yaml.example
BOT_DATABASE_URL=postgresql+asyncpg://books_of_time_user:CHANGE_ME@127.0.0.1:5432/books_of_time
BOT_RAW_DIR=/var/lib/books-of-time/raw
BOT_MEDIA_DIR=/var/lib/books-of-time/media
BOT_ACCOUNT_ENABLED=true
BOT_ACCOUNT_ID=default
BOT_ACCOUNT_CREDENTIALS_PATH=/var/lib/books-of-time/accounts/credentials.enc
BOT_ACCOUNT_KEY_PATH=/var/lib/books-of-time/accounts/master.key
BOT_ACCOUNT_AUTO_REFRESH=true
BOT_ACCOUNT_REFRESH_SECONDS=21600
BOT_INSTANCE_ID=books-of-time
BOT_SERVICE_ROLES=worker,scheduler
BOT_SHUTDOWN_GRACE_SECONDS=60
